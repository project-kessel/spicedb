{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [
    "github-actions",
    "tekton",
    "dockerfile"
  ],
  "includePaths": [
    ".github/workflows/security-scanning.yml",
    ".tekton/**",
    "Dockerfile.fips"
  ],
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "schedule": ["* 0-7 * * 0"]
    }
  ]
}
